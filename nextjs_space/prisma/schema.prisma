generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Participant {
  id                    String   @id @default(cuid())
  name                  String
  whatsapp              String
  estimatedBirthDate    DateTime
  itemName              String?
  pixValue              Int?
  receiptPath           String?
  createdAt             DateTime @default(now())

  @@index([createdAt])
  @@index([estimatedBirthDate])
}
